# Runtime environment: dev | prod
APP_ENV=dev

# API port (used by uvicorn command)
APP_PORT=8000

# Database DSN
# Dev example: sqlite:///./hotel_monitor.db
# Prod example: postgresql+psycopg://user:pass@host:5432/hotel_monitor
DATABASE_URL=sqlite:///./hotel_monitor.db

# JWT config
# In APP_ENV=prod, you MUST replace this with a strong secret.
JWT_SECRET_KEY=dev-secret-change-me
JWT_EXPIRE_MINUTES=720

# Redis DSN for Celery broker/backend and health check
REDIS_URL=redis://localhost:6379/0

# Celery mode
# true  -> execute tasks in-process (test/dev)
# false -> require external worker
CELERY_TASK_ALWAYS_EAGER=false

# Database schema bootstrap
# true  -> auto create tables on app startup
# false -> rely on Alembic migrations (recommended)
AUTO_CREATE_TABLES=false

# AI report generation
# mock     -> local rule-based summary (default)
# deepseek -> call DeepSeek API (requires AI_API_KEY)
# openai   -> call OpenAI-compatible API (requires AI_API_KEY + AI_BASE_URL)
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Push channel
# console    -> write push result into DB only (default)
# serverchan -> Server酱微信推送 (https://sct.ftqq.com, requires PUSH_SERVERCHAN_KEY)
# wxpusher   -> WxPusher微信推送 (https://wxpusher.zjiecode.com, requires PUSH_WXPUSHER_TOKEN + PUSH_WXPUSHER_UIDS)
# webhook    -> post JSON payload to PUSH_WEBHOOK_URL
PUSH_CHANNEL=console
PUSH_WEBHOOK_URL=
PUSH_SERVERCHAN_KEY=
PUSH_WXPUSHER_TOKEN=
PUSH_WXPUSHER_UIDS=

# Activity collection
ACTIVITY_COLLECT_ENABLED=true
ACTIVITY_DEFAULT_RADIUS_KM=3.0
ACTIVITY_CITY_OVERRIDE=

# Amap (高德地图) API key for geocoding activity addresses
# Optional — without it, activities will lack coordinates and distance filtering
# Free tier: https://lbs.amap.com/
AMAP_API_KEY=
